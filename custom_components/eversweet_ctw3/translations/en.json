{
    "config": {
        "flow_title": "{name}",
        "step": {
            "user": {
                "title": "Select CTW3 device",
                "description": "Pick the Petkit_CTW3 device visible to Home Assistant's Bluetooth stack.",
                "data": {
                    "address": "Bluetooth device"
                }
            },
            "confirm": {
                "title": "Authenticate {name}",
                "description": "Enter the 16-character hex secret issued by the PetKit cloud after device binding.\n\nDevice: {name} ({address})",
                "data": {
                    "secret": "Secret (hex)",
                    "name": "Device name"
                }
            }
        },
        "error": {
            "invalid_secret": "Secret must be 16 hex characters (8 bytes)."
        },
        "abort": {
            "already_configured": "Device is already configured.",
            "not_supported": "This Bluetooth device is not a Petkit CTW3.",
            "no_devices_found": "No unconfigured Petkit CTW3 devices were discovered."
        }
    },
    "entity": {
        "sensor": {
            "battery":          { "name": "Battery" },
            "battery_voltage":  { "name": "Battery voltage" },
            "supply_voltage":   { "name": "DC supply voltage" },
            "filter_percent":   { "name": "Filter life" },
            "pump_time_today":  { "name": "Pump today" },
            "pump_time_total":  { "name": "Pump total" },
            "last_drink":       { "name": "Last activity" },
            "run_status":       { "name": "Run code" },
            "module_status":    { "name": "Module code" },
            "firmware":         { "name": "Firmware" },
            "restart_times":    { "name": "Restarts" },
            "run_time_seconds": { "name": "Uptime" },
            "pump_times_total": { "name": "Pump cycles" }
        },
        "binary_sensor": {
            "lack_water":     { "name": "Water level" },
            "low_battery":    { "name": "Low battery" },
            "filter_warning": { "name": "Filter warning" },
            "breakdown":      { "name": "Fault" },
            "night_dnd":      { "name": "Night mode active" },
            "dc_connected":   { "name": "DC power" },
            "running":        { "name": "Pump running" },
            "pet_detected":   { "name": "Pet nearby" }
        },
        "switch": {
            "power":              { "name": "Power" },
            "pause":              { "name": "Pause pump" },
            "dnd":                { "name": "Do not disturb" },
            "child_lock":         { "name": "Child lock" },
            "smart_inductive":    { "name": "Motion sensor (Smart)" },
            "battery_inductive":  { "name": "Motion sensor (Battery)" }
        },
        "select": {
            "mode": {
                "name": "Operating mode",
                "state": {
                    "standard":    "Standard",
                    "intermittent":"Intermittent",
                    "battery":     "Battery"
                }
            },
            "lamp_ring": {
                "name": "Light",
                "state": {
                    "off":    "Off",
                    "low":    "Low",
                    "medium": "Medium",
                    "high":   "High"
                }
            }
        },
        "button": {
            "reset_filter": { "name": "Reset filter counter" },
            "sync_history": { "name": "Download log" }
        },
        "number": {
            "smart_work_minutes":    { "name": "Smart: run time" },
            "smart_sleep_minutes":   { "name": "Smart: pause" },
            "battery_work_seconds":  { "name": "Battery: run time" },
            "battery_sleep_seconds": { "name": "Battery: pause" }
        }
    },
    "services": {
        "write_light_schedule": {
            "name": "Write light schedule",
            "description": "Overwrite the lamp-ring schedule (cmd 225)."
        },
        "write_dnd_schedule": {
            "name": "Write DND schedule",
            "description": "Overwrite the DND schedule (cmd 226)."
        },
        "sync_history": {
            "name": "Sync drinking history",
            "description": "Pull streamed workData records from the device (cmd 212)."
        }
    }
}
